{
  "name": "@kineweave/canvas2d-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./descriptor": {
      "types": "./dist/descriptor.d.ts",
      "import": "./dist/descriptor.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@kineweave/extension-api": "workspace:*",
    "@kineweave/protocol": "workspace:*",
    "@kineweave/render-engine": "workspace:*"
  }
}
