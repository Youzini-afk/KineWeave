{
  "name": "kineweave",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm run build:types && pnpm run build:studio",
    "build:types": "pnpm run check:schema-validators && tsc -b",
    "build:studio": "pnpm --filter @kineweave/studio build:renderer",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "quality": "biome check .",
    "quality:fix": "biome check --write .",
    "generate:schema-validators": "node scripts/generate-schema-validators.mjs",
    "check:schema-validators": "node scripts/generate-schema-validators.mjs --check",
    "generate:goldens": "pnpm run build && node scripts/generate-golden-projects.mjs --update",
    "check:goldens": "node scripts/generate-golden-projects.mjs",
    "clean": "tsc -b --clean",
    "test": "pnpm run test:unit",
    "test:unit": "pnpm run build && pnpm run check:goldens && vitest run",
    "test:e2e": "pnpm run build && vitest run --config vitest.e2e.config.ts",
    "perf": "pnpm run build && pnpm run perf:foundation",
    "perf:foundation": "node scripts/benchmark-foundation.mjs --check",
    "check": "pnpm run quality && pnpm run test:unit && pnpm run perf:foundation",
    "cli": "node apps/cli/dist/index.js",
    "studio": "pnpm run build && pnpm --filter @kineweave/studio start --",
    "example:validate": "node apps/cli/dist/index.js validate examples/hello-kineweave"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@kineweave/history-engine": "workspace:*",
    "@kineweave/official-distribution": "workspace:*",
    "@kineweave/project-format": "workspace:*",
    "@kineweave/project-repository-node": "workspace:*",
    "@kineweave/project-session": "workspace:*",
    "@kineweave/protocol": "workspace:*",
    "@kineweave/standard-motion-document": "workspace:*",
    "@types/node": "22.20.1",
    "ajv": "8.20.0",
    "playwright-core": "1.61.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
